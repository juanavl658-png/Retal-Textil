# =============================================================
# .env.example — Variables de entorno del proyecto
# Sistema de Gestión de Retal Textil
#
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env.local
#   2. Rellena los valores con los datos de tu proyecto Supabase
#   3. NUNCA subas .env.local a Git (ya está en .gitignore)
# =============================================================

# -------------------------------------------------------------
# BASE DE DATOS — Supabase PostgreSQL
# Obtener desde: Supabase Dashboard > Settings > Database
# -------------------------------------------------------------

# URL con pooling (para Prisma en producción / Vercel)
# Formato: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres.[TU-PROJECT-REF]:[TU-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# URL directa (para migraciones Prisma — NO usar con pgbouncer)
# Formato: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DIRECT_URL="postgresql://postgres:[TU-PASSWORD]@db.[TU-PROJECT-REF].supabase.co:5432/postgres"

# -------------------------------------------------------------
# NEXT.JS — Variables públicas (visibles en el navegador)
# -------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Gestión de Retal Textil"
NEXT_PUBLIC_APP_VERSION="1.0.0"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
